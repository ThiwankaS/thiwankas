:8080 {
  root * /usr/share/caddy
  encode zstd gzip
  file_server

  # --- Define matchers OUTSIDE the header block ---
  @html path *.html
  header @html Cache-Control "no-cache, no-store, must-revalidate"
  header @html ETag "{http.response.header.ETag}"

  # Keep CSS/JS revalidating so production reflects latest deploy quickly.
  @codeAssets path *.css *.js
  header @codeAssets Cache-Control "public, max-age=0, must-revalidate"

  # Keep static media aggressively cached.
  @mediaAssets path *.svg *.png *.jpg *.jpeg *.webp *.gif *.ico *.pdf
  header @mediaAssets Cache-Control "public, max-age=31536000, immutable"

  # --- General security-ish headers in a regular header block ---
  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(), microphone=()"
  }
}
